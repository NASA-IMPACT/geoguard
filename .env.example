# =============================================================================
# GeoGuard Environment Variables
# =============================================================================
# Copy this file to .env and fill in your keys.
#   cp .env.example .env

# --- LLM Provider (required — pick one) ------------------------------------

# OpenAI
OPENAI_API_KEY=sk-...

# --- GeoGuard Settings (optional — all have defaults) ----------------------

# GEOGUARD_MODEL=openai:gpt-5.2
# GEOGUARD_REASONING_EFFORT=medium          # low | medium | high
# GEOGUARD_API_KEY=                          # override per-provider key above
# GEOGUARD_MAX_CLAIMS=15
# GEOGUARD_HTTP_TIMEOUT_SECONDS=30.0
# GEOGUARD_VERIFICATION_TOOL_USAGE_LIMIT=    # e.g. 15 to cap tool calls per claim

# --- NASA Earthdata (required for MODIS satellite flood tool) ---------------
# Register at: https://urs.earthdata.nasa.gov/users/new

EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# --- LAADS Archive (required for historical MODIS data, 2003-present) -------
# Get your app key at: https://ladsweb.modaps.eosdis.nasa.gov/profiles

# LAADS_APP_KEY=
